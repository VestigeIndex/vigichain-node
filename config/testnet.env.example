# VigiChain testnet node — example environment.
# Export these before launching, or copy to `.env`.

# Network to join. This distribution is for the public testnet.
VIGI_NETWORK=testnet

# Address that receives mined testnet rewards (optional). tvigi1...
# VIGI_MINER_ADDRESS=tvigi1youraddresshere

# Custom bootstrap peers (comma-separated host:port), or `local` for a private lab.
# Leave unset to use the network default.
# VIGI_BOOTNODES=

# Where chain data and the node identity keystore are stored.
# VIGI_DATA_DIR=./vigi-data

# Node identity keystore path (created once, owner-only, never printed).
# VIGI_NODE_KEY_PATH=./vigi-data/node_key.json
